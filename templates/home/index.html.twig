{% extends 'base.html.twig' %}

{% block title %}Création de Site Internet en Bretagne pour TPE | Alré Web{% endblock %}

{% block meta_description %}Développeur web freelance en Bretagne. Création de sites vitrines, e-commerce et référencement pour indépendants et TPE. Basé à Auray. Devis gratuit sous 48h.{% endblock %}

{% block body %}

{# ============================================
   HERO SECTION - Accroche principale
   ============================================ #}
<section class="hero">
    <div class="hero-layout">
        {% if company and company.homePortraitPhoto %}
        {% set srcset = responsive_srcset('uploads/profile/' ~ company.homePortraitPhoto) %}
        <div class="hero-portrait-wrapper fade-in">
            <div class="hero-portrait-left">
                <img src="{{ asset('uploads/profile/' ~ company.homePortraitPhoto) }}"
                     {% if srcset %}srcset="{{ srcset }}"
                     sizes="(max-width: 992px) 200px, 260px"{% endif %}
                     alt="Fabrice Dhuicque"
                     width="260"
                     height="350"
                     fetchpriority="high">
            </div>
        </div>
        {% endif %}
        <div class="hero-text">
            <h1 class="fade-in">
                Création de site internet en Bretagne
                <br>
                <span class="text-accent">le site qui attire des clients pendant que vous travaillez</span>
            </h1>
            <p class="lead fade-in-delay-1">
                Artisans, commerçants, indépendants, TPE : je crée le site web qui vous rend visible sur Google,
                vend vos produits 24h/24 et vous libère des tracas techniques.
                Sites vitrines <a href="{{ path('app_pricing') }}" style="color: inherit; text-decoration: underline;">dès {{ offers.page_unique.formattedCurrentPrice }} € HT</a>.
            </p>
            <div class="hero-cta fade-in-delay-2">
                <a href="{{ path('app_contact') }}" class="btn btn-primary btn-lg">
                    <i class="fas fa-paper-plane"></i> Demander un devis gratuit
                </a>
                <a href="{{ path('app_portfolio') }}" class="btn btn-secondary btn-lg">
                    <i class="fas fa-folder-open"></i> Voir mes réalisations
                </a>
            </div>
        </div>
    </div>
</section>

{# ============================================
   PROPOSITION DE VALEUR - 4 piliers
   ============================================ #}
<section class="section">
    <div class="container">
        <h2 class="text-center mb-3">Ce que vous gagnez en travaillant avec moi</h2>
        <p class="text-center text-muted mb-5">
            Un site qui travaille pour vous, pas l'inverse
        </p>

        <div class="grid grid-4">
            <div class="card service-card">
                <div class="card-icon">
                    <i class="fas fa-search"></i>
                </div>
                <h3 class="card-title">Des clients vous trouvent</h3>
                <p class="card-text">
                    Fini l'invisibilité sur Google. Votre site apparaît quand vos futurs clients cherchent vos services.
                    Plus de visibilité = plus de demandes.
                </p>
            </div>

            <div class="card service-card">
                <div class="card-icon">
                    <i class="fas fa-clock"></i>
                </div>
                <h3 class="card-title">Vous gagnez du temps</h3>
                <p class="card-text">
                    Devis automatiques, prises de RDV en ligne, ventes 24h/24...
                    Votre site travaille pendant que vous êtes sur le terrain ou en repos.
                </p>
            </div>

            <div class="card service-card">
                <div class="card-icon">
                    <i class="fas fa-shield-alt"></i>
                </div>
                <h3 class="card-title">Zéro tracas technique</h3>
                <p class="card-text">
                    Hébergement, mises à jour, sécurité, sauvegardes : je gère tout.
                    Vous n'avez pas besoin de comprendre la technique pour avoir un site pro.
                </p>
            </div>

            <div class="card service-card">
                <div class="card-icon">
                    <i class="fas fa-handshake"></i>
                </div>
                <h3 class="card-title">Un seul interlocuteur</h3>
                <p class="card-text">
                    Pas d'agence avec 5 contacts différents. Vous m'appelez, je réponds.
                    Communication directe, décisions rapides, projet qui avance.
                </p>
            </div>
        </div>
    </div>
</section>

{# ============================================
   SERVICES EN RÉSUMÉ - 6 cartes cliquables
   ============================================ #}
<section class="section section-light">
    <div class="container">
        <h2 class="text-center mb-3">Comment je peux vous aider</h2>
        <p class="text-center text-muted mb-5">
            Des solutions concrètes pour développer votre activité en ligne
        </p>

        <div class="grid grid-3">
            {# Service 1 - Site vitrine #}
            <div class="card">
                <div class="card-icon">
                    <i class="fas fa-globe"></i>
                </div>
                <h3 class="card-title">Être trouvé sur Google</h3>
                <p class="card-text">
                    Un site vitrine optimisé pour que vos clients vous trouvent
                    quand ils cherchent vos services. Fini l'invisibilité.
                </p>
                <a href="{{ path('app_service_creation') }}" class="card-link">
                    Création de site internet
                </a>
            </div>

            {# Service 2 - E-commerce #}
            <div class="card">
                <div class="card-icon">
                    <i class="fas fa-shopping-cart"></i>
                </div>
                <h3 class="card-title">Vendre en ligne 24h/24</h3>
                <p class="card-text">
                    Une boutique qui prend les commandes même quand vous dormez.
                    Élargissez votre clientèle au-delà de votre zone géographique.
                </p>
                <a href="{{ path('app_service_creation') }}" class="card-link">
                    Sites e-commerce
                </a>
            </div>

            {# Service 3 - Automatisation #}
            <div class="card">
                <div class="card-icon">
                    <i class="fas fa-robot"></i>
                </div>
                <h3 class="card-title">Automatiser les tâches répétitives</h3>
                <p class="card-text">
                    Devis, factures, prises de RDV, relances... Libérez-vous des tâches
                    chronophages avec des outils sur mesure.
                </p>
                <a href="{{ path('app_service_developpeur') }}" class="card-link">
                    Développement sur mesure
                </a>
            </div>

            {# Service 4 - Hébergement #}
            <div class="card">
                <div class="card-icon">
                    <i class="fas fa-server"></i>
                </div>
                <h3 class="card-title">Ne plus se soucier de la technique</h3>
                <p class="card-text">
                    Hébergement, sécurité, mises à jour, sauvegardes : je gère tout.
                    Vous avez un site pro sans rien y connaître.
                </p>
                <a href="{{ path('app_service_agence') }}" class="card-link">
                    Accompagnement complet
                </a>
            </div>

            {# Service 5 - SEO #}
            <div class="card">
                <div class="card-icon">
                    <i class="fas fa-chart-line"></i>
                </div>
                <h3 class="card-title">Attirer plus de clients</h3>
                <p class="card-text">
                    Référencement optimisé pour apparaître en haut des résultats Google.
                    Plus de visibilité = plus de demandes de devis.
                </p>
                <a href="{{ path('app_service_referencement') }}" class="card-link">
                    Référencement local
                </a>
            </div>

            {# Service 6 - Tarifs #}
            <div class="card">
                <div class="card-icon">
                    <i class="fas fa-euro-sign"></i>
                </div>
                <h3 class="card-title">Des tarifs transparents</h3>
                <p class="card-text">
                    Sites vitrines dès {{ offers.page_unique.formattedCurrentPrice }} € HT, e-commerce dès {{ offers.ecommerce.formattedCurrentPrice }} € HT.
                    Prix clairs, devis détaillé, sans surprise.
                </p>
                <a href="{{ path('app_pricing') }}" class="card-link">
                    Voir les tarifs
                </a>
            </div>
        </div>

        <div class="text-center mt-5">
            <a href="{{ path('app_services') }}" class="btn btn-outline btn-lg">
                <i class="fas fa-list"></i> Voir tous les services en détail
            </a>
        </div>
    </div>
</section>

{# ============================================
   PROJETS MIS EN AVANT
   ============================================ #}
{% if featuredProjects is defined and featuredProjects|length > 0 %}
<section class="section">
    <div class="container">
        <h2 class="text-center mb-3">Mes Réalisations</h2>
        <p class="text-center text-muted mb-5">
            Quelques projets dont je suis fier
        </p>

        <div class="grid grid-{{ featuredProjects|length == 1 ? '1' : (featuredProjects|length == 2 ? '2' : '3') }}">
            {% for project in featuredProjects %}
            <div class="card project-card">
                {% if project.featuredImage %}
                    <div class="card-image">
                        <img src="{{ asset('uploads/projects/' ~ project.featuredImage.imageFilename) }}"
                             alt="{{ project.title }}"
                             loading="lazy">
                    </div>
                {% endif %}
                <div class="card-body">
                    <h3 class="card-title">{{ project.title }}</h3>
                    <p class="card-text">{{ project.shortDescription }}</p>
                    <div class="card-technologies">
                        {% for tech in project.technologies|slice(0, 4) %}
                            <span class="badge">{{ tech }}</span>
                        {% endfor %}
                    </div>
                </div>
                <div class="card-footer">
                    <a href="{{ path('app_portfolio_show', {'slug': project.slug}) }}" class="card-link">
                        Voir le projet
                    </a>
                </div>
            </div>
            {% endfor %}
        </div>

        <div class="text-center mt-5">
            <a href="{{ path('app_portfolio') }}" class="btn btn-outline btn-lg">
                <i class="fas fa-folder-open"></i> Voir tous les projets
            </a>
        </div>
    </div>
</section>
{% endif %}

{# ============================================
   TÉMOIGNAGES
   ============================================ #}
{% if testimonials is defined and testimonials|length > 0 %}
<section class="section section-light">
    <div class="container">
        <h2 class="text-center mb-3">Ce que disent mes clients</h2>
        <p class="text-center text-muted mb-5">
            Leur satisfaction est ma priorité
        </p>

        <div class="grid grid-{{ testimonials|length == 1 ? '1' : (testimonials|length == 2 ? '2' : '3') }}">
            {% for testimonial in testimonials %}
            <div class="testimonial-card">
                <div class="rating">
                    <span class="rating-stars" aria-label="{{ testimonial.rating }} sur 5">{% for i in 1..5 %}{% if i <= testimonial.rating %}★{% else %}☆{% endif %}{% endfor %}</span>
                </div>
                <p class="testimonial-text">{{ testimonial.content }}</p>
                <div class="testimonial-author">
                    <div>
                        <div class="testimonial-author-name">{{ testimonial.clientName }}</div>
                        <div class="testimonial-author-company">{{ testimonial.clientCompany }}</div>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
</section>
{% endif %}

{# ============================================
   AVIS GOOGLE - Preuve sociale
   ============================================ #}
{% if googleReviews is defined and googleReviews|length > 0 %}
<section class="section">
    <div class="container">
        <h2 class="text-center mb-3">
            <i class="fab fa-google" style="color: #4285F4;"></i>
            Avis Google
        </h2>
        <p class="text-center text-muted mb-4">
            Ce que mes clients disent sur Google
        </p>

        {# Bandeau note moyenne #}
        {% if googleReviewStats is defined and googleReviewStats.approved > 0 %}
        <div class="text-center mb-5">
            <div style="display: inline-flex; align-items: center; gap: 1rem; background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%); padding: 1rem 2rem; border-radius: 50px; box-shadow: 0 2px 8px rgba(0,0,0,0.08);">
                {# Étoiles visuelles #}
                {% set avgRating = googleReviewStats.averageRating|default(0) %}
                <span class="rating-stars rating-stars-lg" aria-label="{{ avgRating|number_format(1, ',', ' ') }} sur 5">{% for i in 1..5 %}{% if i <= avgRating|round(0, 'floor') %}★{% elseif i - 0.5 <= avgRating %}★{% else %}☆{% endif %}{% endfor %}</span>
                {# Note et nombre d'avis #}
                <div style="font-size: 1.1rem;">
                    <strong style="color: #111827;">{{ avgRating|number_format(1, ',', ' ') }}/5</strong>
                    <span style="color: #6b7280;">
                        basé sur {{ googleReviewStats.approved }} avis{{ googleReviewStats.approved > 1 ? '' : '' }}
                    </span>
                </div>
                {# Badge Excellent si note >= 4.5 #}
                {% if avgRating >= 4.5 %}
                <span style="background: linear-gradient(135deg, var(--accent-color) 0%, #1e8a98 100%); color: white; padding: 0.35rem 0.85rem; border-radius: 20px; font-size: 0.85rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px;">
                    Excellent
                </span>
                {% endif %}
            </div>
        </div>
        {% endif %}

        <div class="reviews-carousel" aria-label="Avis Google">
            <div class="reviews-carousel-track">
                {% for review in googleReviews %}
                <div class="reviews-carousel-slide">
                    <div class="testimonial-card">
                        <div class="rating">
                            <span class="rating-stars" aria-label="{{ review.rating }} sur 5">{% for i in 1..5 %}{% if i <= review.rating %}★{% else %}☆{% endif %}{% endfor %}</span>
                        </div>
                        {% if review.comment %}
                        <p class="testimonial-text">{{ review.commentExcerpt(200) }}</p>
                        {% else %}
                        <p class="testimonial-text" style="font-style: italic; opacity: 0.7;">(Avis sans commentaire)</p>
                        {% endif %}
                        <div class="testimonial-author">
                            <div>
                                <div class="testimonial-author-name">{{ review.authorName }}</div>
                                <div class="testimonial-author-company">
                                    <i class="fab fa-google" style="color: #4285F4; font-size: 0.85rem;"></i>
                                    {{ review.reviewDate|format_datetime(pattern='MMMM yyyy', locale='fr') }}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
            <div class="reviews-carousel-nav">
                <button class="reviews-carousel-btn reviews-carousel-btn--prev" aria-label="Avis précédents">&#8249;</button>
                <div class="reviews-carousel-dots"></div>
                <button class="reviews-carousel-btn reviews-carousel-btn--next" aria-label="Avis suivants">&#8250;</button>
            </div>
        </div>

        {# Lien vers tous les avis Google #}
        {% if googlePlaceId is defined and googlePlaceId %}
        <div class="text-center mt-4">
            <a href="https://search.google.com/local/reviews?placeid={{ googlePlaceId }}"
               target="_blank"
               rel="noopener noreferrer"
               class="btn btn-outline"
               style="border-color: #4285F4; color: #4285F4;">
                <i class="fab fa-google"></i>
                Voir tous les avis sur Google
                <i class="fas fa-external-link-alt" style="font-size: 0.75rem; margin-left: 0.25rem;"></i>
            </a>
        </div>
        {% endif %}
    </div>
</section>
{% endif %}

{# ============================================
   ÉCOCONCEPTION - Badge et CTA
   ============================================ #}
<section class="section eco-section">
    <div class="container">
        <div class="eco-banner">
            <div class="eco-badge-container">
                <div class="eco-badge-large">A</div>
                <span class="eco-badge-label">EcoIndex</span>
            </div>
            <div class="eco-banner-content">
                <h2>Un site web éco-responsable</h2>
                <p>
                    Ce site est conçu selon les principes de l'écoconception numérique :
                    léger, rapide, économe en ressources. <strong>Plus propre que 95% des sites web.</strong>
                </p>
                <a href="{{ path('app_ecoconception') }}" class="btn btn-outline">
                    <i class="fas fa-leaf"></i> Découvrir mon engagement
                </a>
            </div>
        </div>
    </div>
</section>

{# ============================================
   CTA FINAL - Appel à l'action
   ============================================ #}
<section class="section section-light">
    <div class="container text-center">
        <h2 class="mb-3">Prêt à avoir un site qui vous ramène des clients ?</h2>
        <p class="lead mb-4">
            Basé à Auray, j'accompagne les artisans, indépendants et TPE de toute la Bretagne.
            <br>
            Premier échange gratuit et sans engagement.
        </p>
        <div style="display: inline-flex; gap: 1rem; flex-wrap: wrap; justify-content: center;">
            <a href="{{ path('app_contact') }}" class="btn btn-primary btn-lg">
                <i class="fas fa-paper-plane"></i> Demander un devis gratuit
            </a>
            <a href="{{ path('app_pricing') }}" class="btn btn-outline btn-lg">
                <i class="fas fa-euro-sign"></i> Voir les tarifs
            </a>
        </div>
        <p class="mt-4" style="font-size: 0.95rem; color: var(--text-muted);">
            <i class="fas fa-clock"></i> Réponse sous 24h garantie
        </p>
    </div>
</section>

{% endblock %}
