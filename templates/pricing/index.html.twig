{% extends 'base.html.twig' %}

{% block title %}Tarifs Création Site Internet Bretagne | Prix Transparents | Alré Web{% endblock %}

{% block meta_description %}Tarifs transparents pour la création de sites web en Bretagne. Sites vitrines dès {{ offers.page_unique.formattedCurrentPrice }} €, e-commerce, packs SEO dès {{ offers.seo_visibilite.formattedCurrentPrice }} €/mois. Devis gratuit sous 48h.{% endblock %}

{% block structured_data %}
{{ parent() }}
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
        {
            "@type": "Question",
            "name": "Combien coûte une page unique ?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "Une page unique démarre à {{ offers.page_unique.formattedCurrentPrice }} € HT. Elle comprend un design moderne et responsive, un formulaire de contact, l'optimisation SEO de base, l'intégration de vos contenus et 1 mois de support offert."
            }
        },
        {
            "@type": "Question",
            "name": "Combien coûte un site vitrine ?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "Un site vitrine de 4-5 pages démarre à {{ offers.site_vitrine.formattedCurrentPrice }} € HT. Il comprend un design moderne, un formulaire de contact, l'optimisation SEO, la formation à la gestion et 2 mois de support offert."
            }
        },
        {
            "@type": "Question",
            "name": "Combien coûte un site e-commerce ?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "Un site e-commerce avec jusqu'à 50 produits démarre à {{ offers.ecommerce.formattedCurrentPrice }} € HT. Il comprend le catalogue produits, le panier et paiement sécurisé, la gestion des stocks et commandes, l'espace client et 3 mois de support."
            }
        },
        {
            "@type": "Question",
            "name": "Proposez-vous des facilités de paiement ?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "Oui, je propose un acompte de 30% à la validation du devis, un paiement échelonné possible selon le projet, et le solde à la livraison du site."
            }
        },
        {
            "@type": "Question",
            "name": "Combien coûtent les packs SEO ?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "Le Pack Essentiel (audit SEO complet) coûte {{ offers.seo_essentiel.formattedCurrentPrice }} € HT. Le Pack Visibilité (SEO local mensuel) est à {{ offers.seo_visibilite.formattedCurrentPrice }} € HT/mois pendant la durée de l'engagement (puis {{ offers.seo_visibilite.price|number_format(0, ',', ' ') }} € HT/mois). Le Pack Performance (accompagnement SEO complet) est à {{ offers.seo_performance.formattedCurrentPrice }} € HT/mois pendant la durée de l'engagement (puis {{ offers.seo_performance.price|number_format(0, ',', ' ') }} € HT/mois). Engagement minimum de 6 mois pour les packs mensuels."
            }
        }
    ]
}
</script>
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "AggregateOffer",
    "name": "Création de sites web et référencement SEO",
    "description": "Tarifs pour la création de sites internet et référencement SEO en Bretagne",
    "url": "https://alre-web.bzh/tarifs",
    "lowPrice": "{{ offers.seo_visibilite.schemaPrice }}",
    "highPrice": "{{ offers.ecommerce.schemaPrice }}",
    "priceCurrency": "EUR",
    "offerCount": "9",
    "offers": [
        {
            "@type": "Offer",
            "name": "Page Unique",
            "price": "{{ offers.page_unique.schemaPrice }}",
            "priceCurrency": "EUR",
            "description": "Une page complète et optimisée avec design moderne et responsive"
        },
        {
            "@type": "Offer",
            "name": "Site Vitrine",
            "price": "{{ offers.site_vitrine.schemaPrice }}",
            "priceCurrency": "EUR",
            "description": "Site de 4-5 pages personnalisées avec formation à la gestion"
        },
        {
            "@type": "Offer",
            "name": "Site E-commerce",
            "price": "{{ offers.ecommerce.schemaPrice }}",
            "priceCurrency": "EUR",
            "description": "Boutique en ligne jusqu'à 50 produits avec paiement sécurisé"
        },
        {
            "@type": "Offer",
            "name": "Hébergement + Maintenance",
            "price": "{{ offers.hebergement_maintenance.schemaPrice }}",
            "priceCurrency": "EUR",
            "description": "Hébergement performant en France avec maintenance technique et support"
        },
        {
            "@type": "Offer",
            "name": "Hébergement Seul",
            "price": "{{ offers.hebergement.schemaPrice }}",
            "priceCurrency": "EUR",
            "description": "Hébergement performant en France avec SSL et sauvegardes"
        },
        {
            "@type": "Offer",
            "name": "Pack SEO Essentiel",
            "price": "{{ offers.seo_essentiel.schemaPrice }}",
            "priceCurrency": "EUR",
            "description": "Audit SEO complet avec plan d'action priorisé et session de conseil"
        },
        {
            "@type": "Offer",
            "name": "Pack SEO Visibilité",
            "price": "{{ offers.seo_visibilite.schemaPrice }}",
            "priceCurrency": "EUR",
            "description": "SEO local mensuel avec Google Business Profile et suivi des positions"
        },
        {
            "@type": "Offer",
            "name": "Pack SEO Performance",
            "price": "{{ offers.seo_performance.schemaPrice }}",
            "priceCurrency": "EUR",
            "description": "Accompagnement SEO complet avec stratégie de mots-clés et optimisations continues"
        }
    ]
}
</script>
{% endblock %}

{% block body %}

{# Hero Section #}
<section class="hero" style="padding: 4rem 0;">
    <div class="hero-content">
        <h1 class="fade-in">Tarifs transparents : sites web dès {{ offers.page_unique.formattedCurrentPrice }} €</h1>
        <p class="lead fade-in-delay-1">
            Des prix transparents et adaptés à votre projet<br>
            Devis personnalisé gratuit
        </p>
        <p class="fade-in-delay-2" style="font-size: 0.9rem; color: var(--text-muted); margin-top: 0.5rem;">
            Prix HT, TVA non applicable, art. 293 B du CGI
        </p>
    </div>
</section>

{% if hasActivePromo %}
{# Bannière offre de lancement #}
<div class="launch-banner fade-in-delay-2">
    <div class="launch-banner-inner">
        <span class="launch-badge">Offre de lancement</span>
        <span class="launch-text">
            Tarifs préférentiels pour toute <strong>signature de devis avant le {{ latestPromoEndDate|date('j') }}{% if latestPromoEndDate|date('n') == 1 %} janvier{% elseif latestPromoEndDate|date('n') == 2 %} février{% elseif latestPromoEndDate|date('n') == 3 %} mars{% elseif latestPromoEndDate|date('n') == 4 %} avril{% elseif latestPromoEndDate|date('n') == 5 %} mai{% elseif latestPromoEndDate|date('n') == 6 %} juin{% elseif latestPromoEndDate|date('n') == 7 %} juillet{% elseif latestPromoEndDate|date('n') == 8 %} août{% elseif latestPromoEndDate|date('n') == 9 %} septembre{% elseif latestPromoEndDate|date('n') == 10 %} octobre{% elseif latestPromoEndDate|date('n') == 11 %} novembre{% else %} décembre{% endif %} {{ latestPromoEndDate|date('Y') }}</strong>
        </span>
    </div>
</div>
{% endif %}

{# Introduction #}
<section class="section">
    <div class="container text-center" style="max-width: 800px; margin: 0 auto;">
        <p class="lead">
            Chaque projet est unique, c'est pourquoi je propose des <strong>tarifs indicatifs "à partir de"</strong>
            pour la <a href="{{ path('app_service_creation') }}" style="color: var(--accent-dark);">création de sites internet</a> en Bretagne.
            Après avoir discuté de vos besoins, je vous fournis un <strong>devis détaillé et personnalisé</strong>.
        </p>
        <p style="color: var(--text-muted);">
            En tant que <a href="{{ path('app_service_developpeur') }}" style="color: var(--accent-dark);">développeur web freelance</a>,
            mes prix sont <strong>plus compétitifs qu'une agence</strong> tout en maintenant
            un niveau de qualité professionnel. Pas de frais de structure, juste un service de qualité.
        </p>
    </div>
</section>

